{
  "name": "devcode",
  "displayName": "devcode",
  "description": "AI-powered coding assistant using a local Python backend.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:devcodeChatView"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devcode.aiAgent",
        "title": "DevCode: Open Chat Sidebar"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devcodeSidebar",
          "title": "DevCode",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "devcodeSidebar": [
        {
          "id": "devcodeChatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "DevCode",
      "properties": {
        "devcode.selectedModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Currently selected AI model for DevCode extension"
        },
        "devcode.useOfflineAI": {
          "type": "boolean",
          "default": false,
          "description": "Use local AI models instead of online API"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1"
  }
}
